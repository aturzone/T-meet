# Example logrotate config for T-meet, used only when run.sh / meet-server is
# pointed at a file rather than journald.
#
# Install:
#   sudo cp examples/logrotate-meet /etc/logrotate.d/meet
#
# T-meet itself logs to stdout; this file assumes you've redirected it to
# /var/log/meet/meet-server.log via your service wrapper.

/var/log/meet/meet-server.log {
    daily
    rotate 14
    compress
    delaycompress
    missingok
    notifempty
    create 0640 meet meet
    sharedscripts
    postrotate
        systemctl kill --signal=SIGUSR1 meet-platform 2>/dev/null || true
    endscript
}
