root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

[*.rs]
indent_size = 4
max_line_length = 100

[*.{toml,lock}]
indent_size = 4

[*.{ts,tsx,js,jsx,mjs,cjs,json,jsonc,yml,yaml,md,html,css,scss,vue}]
indent_size = 2

[*.{sh,bash}]
indent_size = 2

[Makefile]
indent_style = tab

[justfile]
indent_style = tab

[*.md]
trim_trailing_whitespace = false
