# Normalize line endings — LF everywhere
* text=auto eol=lf

# Explicit text files
*.rs        text eol=lf diff=rust
*.toml      text eol=lf
*.md        text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.json      text eol=lf
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.jsx       text eol=lf
*.css       text eol=lf
*.html      text eol=lf
*.sh        text eol=lf
Makefile    text eol=lf
justfile    text eol=lf
Dockerfile  text eol=lf

# Binary
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.webp      binary
*.ico       binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.otf       binary
*.pdf       binary
*.tar.gz    binary
*.zip       binary

# Lockfiles — diff-friendly, no LFS, mark as generated for review brevity
Cargo.lock        linguist-generated=true
pnpm-lock.yaml    linguist-generated=true
package-lock.json linguist-generated=true

# Exclude planning + docs from release archives
docs/plan/        export-ignore
.github/          export-ignore
tests/            export-ignore
playwright/       export-ignore
*.md              export-ignore
LICENSE           export-include
